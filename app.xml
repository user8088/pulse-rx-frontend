}

#magic-cursor {
  pointer-events: none;
}

#ball {
  pointer-events: none;
  user-select: none;
}

.ball-view {
  pointer-events: none;
  user-select: none;
}

/* Lenis smooth scroll essential styles */
html.lenis {
  height: auto;
}

.lenis.lenis-smooth {
  scroll-behavior: auto !important;
}

.lenis.lenis-smooth [data-lenis-prevent] {
  overscroll-behavior: contain;
}

.lenis.lenis-stopped {
  overflow: hidden;
}

.lenis.lenis-scrolling iframe {
  pointer-events: none;
}

/* Product Image Animation */
@keyframes fadeIn {
