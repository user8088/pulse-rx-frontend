<file path="globals.css">
@import "tailwindcss";

@theme {
  --font-sans: var(--font-geist-sans);
  --font-mono: var(--font-geist-mono);
  
  /* Brand Palette */
  --color-brand-primary: #01AC28;
  --color-brand-dark: #044644;
  --color-brand-light: #5C9D40;
  
  /* UI Colors */
  --color-ui-white: #FFFFFF;
  --color-ui-gray-light: #EFEFEF;
  --color-ui-gray-medium: #9CA3AF;
  --color-ui-gray-dark: #374151;
  --color-ui-black: #000000;
}

:root {
  --background: #ffffff;
  --foreground: #111827;
  --brand-primary: #01AC28;
  --brand-dark: #044644;
  --brand-light: #5C9D40;
  --ui-gray-light: #f9fafb;
}

@layer base {
  body {
    @apply bg-white text-gray-900;
    font-family: var(--font-geist-sans), ui-sans-serif, system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
}

/* Hide scrollbar for mobile navigation */
.scrollbar-hide {
  -ms-overflow-style: none;
  scrollbar-width: none;
}

.scrollbar-hide::-webkit-scrollbar {
  display: none;
}

/* Magic Cursor Styles */
@media (min-width: 768px) {
  body.magic-cursor-active {
    cursor: none;
  }
  
  body.magic-cursor-active * {
    cursor: none !important;
  }
  
  /* Allow pointer cursor on interactive elements for better UX */
  body.magic-cursor-active button,
  body.magic-cursor-active a,
  body.magic-cursor-active input,
  body.magic-cursor-active select,
  body.magic-cursor-active textarea,
  body.magic-cursor-active [data-cursor-hide] {
    cursor: pointer !important;
  }
}

#magic-cursor {
  pointer-events: none;
}

#ball {
  pointer-events: none;
  user-select: none;
}

.ball-view {
  pointer-events: none;
  user-select: none;
}

/* Lenis smooth scroll essential styles */
html.lenis {
  height: auto;
}

.lenis.lenis-smooth {
  scroll-behavior: auto !important;
}

.lenis.lenis-smooth [data-lenis-prevent] {
  overscroll-behavior: contain;
}

.lenis.lenis-stopped {
  overflow: hidden;
}

.lenis.lenis-scrolling iframe {
  pointer-events: none;
}

/* Product Image Animation */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: scale(0.95);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}
