                                  </form>
                                ) : (
                                  <span className="inline-flex items-center gap-2 rounded-xl border border-green-200 bg-green-50 px-3 py-2 text-[10px] font-extrabold uppercase tracking-[0.2em] text-green-700">
                                    <Star className="h-4 w-4" />
