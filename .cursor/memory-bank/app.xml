          <form
            action={async (formData) => {
              await onUpdateName(formData);
              setEditingName(false);
            }}
            className="flex items-center gap-2"
            onSubmit={() => setEditingName(false)}
          >
            <input type="hidden" name="customer_id" value={customerId} />
