  const res = await dashboardFetch(`/dashboard/prescriptions/${id}/file`, {
    cache: "no-store",
  });
  if (!res.ok) {
    return NextResponse.json(
      { error: "Could not retrieve file URL" },
      { status: res.status }
    );
  }
  const data = await res.json();
  return NextResponse.json(data);
}
