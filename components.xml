    : null;

  if (compact) {
    return (
      <div className="rounded-2xl bg-gradient-to-r from-[#01AC28] via-[#00C853] to-[#00E676] overflow-hidden shadow-md text-white">
        {bannerUrl && (
          <div className="relative w-full aspect-[3/1] min-h-[120px] bg-black/10">
